# Anthropic API key — get from console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM model used by the agent
# Faster and cheaper: claude-haiku-4-5
# More capable: claude-sonnet-4-6
MODEL=claude-haiku-4-5

# LLM provider — anthropic, google_genai, openai
PROVIDER=anthropic

# Embedding model — sentence_transformers (local, no API key needed)
# all-MiniLM-L6-v2 → 384 dims, fast, 80MB
# all-mpnet-base-v2 → 768 dims, more accurate, 420MB
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector DB backend
MEMORY_BACKEND=qdrant
COLLECTION_NAME=agent_memory

# Qdrant (used when MEMORY_BACKEND=qdrant)
# No QDRANT_URL → local file at QDRANT_PATH (test/dev, persists between runs)
# QDRANT_URL set → Qdrant Cloud (deploy)
QDRANT_PATH=qdrant_db
# QDRANT_URL=https://xxx.qdrant.io:6333
# QDRANT_API_KEY=...

# # LangSmith tracing (optional) — get from smith.langchain.com
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=your-project-name