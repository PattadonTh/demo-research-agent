# Anthropic API key — get from console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# LLM model used by the agent
# Faster and cheaper: claude-haiku-4-5
# More capable: claude-sonnet-4-6
MODEL=claude-haiku-4-5

# LLM provider — anthropic, google_genai, openai
PROVIDER=anthropic

# Embedding model for vector memory
# Runs locally — no API key needed, model downloads automatically on first run
# Options: all-MiniLM-L6-v2 (fast, 80MB) | all-mpnet-base-v2 (accurate, 420MB)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector DB backend — chroma (default), qdrant, pinecone
MEMORY_BACKEND=chroma
CHROMA_DIR=chroma_db
COLLECTION_NAME=agent_memory

# # LangSmith tracing (optional) — get from smith.langchain.com
# LANGCHAIN_API_KEY=ls__...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=your-project-name